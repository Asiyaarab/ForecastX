# ──────────────────────────────────────────────────────────────────────
# Environment & secrets (CRITICAL — never commit)
# Especially important for ForecastX: a hardcoded login lived in app.py
# for a while. .env + secrets.toml are the right way to keep keys out of
# source control from now on.
# ──────────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.env
secrets.toml
secrets.json
**/secrets.*

# ──────────────────────────────────────────────────────────────────────
# Streamlit
# ──────────────────────────────────────────────────────────────────────
.streamlit/secrets.toml

# ──────────────────────────────────────────────────────────────────────
# OS / runtime junk
# ──────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.log
*.bak
*.tmp

# ──────────────────────────────────────────────────────────────────────
# Large data files (already committed once — see note below)
# ──────────────────────────────────────────────────────────────────────
# train.csv is 13 MB. Once a file is tracked by git, adding it here
# does NOT remove it from history. If you want to stop tracking it:
#   git rm --cached train.csv
#   git rm --cached test.csv
#   git rm --cached features.csv
#   git rm --cached sales_forecasting_banner.jpg
#   git commit -m "chore: untrack large data + banner, use .gitignore"
#   git push
# Then uncomment the lines below to prevent future commits:
#
# train.csv
# test.csv
# features.csv
# sales_forecasting_banner.jpg

# ──────────────────────────────────────────────────────────────────────
# ML model artifacts (regenerate via train.py, don't commit)
# ──────────────────────────────────────────────────────────────────────
*.pkl
*.joblib
*.h5
*.pt
*.pth
models/
artifacts/
checkpoints/

# ──────────────────────────────────────────────────────────────────────
# Jupyter / notebooks
# ──────────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

.model_cache/
venv/
